# ─────────────────────────────────────────────────────────────
# fanvault-user-auth-service — Environment Configuration
# Copy this file to .env and fill in all required values.
# Never commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# Purpose  : Express listening port
# Required : Yes
# Secret   : No
PORT=3001

# Purpose  : Node.js runtime context
# Required : Yes
# Secret   : No
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────
# Purpose  : MongoDB connection string pointing to the consolidated DB
#            Use the Route53 private DNS name — NOT an IP address
# Required : Yes
# Secret   : YES — treat as a secret, use AWS Secrets Manager or SSM
# Example  : mongodb://dbuser:CHANGE_ME@db.fanvault.internal:27017/fanvault_db?authSource=admin
MONGO_URI=mongodb://dbuser:CHANGE_ME@db.fanvault.internal:27017/fanvault_db?authSource=admin

# ── JWT ───────────────────────────────────────────────────────
# Purpose  : Signing secret for short-lived access tokens (shared with Commerce Service)
# Required : Yes
# Secret   : YES — minimum 32 random bytes, base64 encoded
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# Purpose  : Expiry duration of access tokens
# Required : No (defaults to 15m)
# Secret   : No
JWT_EXPIRES_IN=15m

# Purpose  : Signing secret for long-lived refresh tokens (kept only in this service)
# Required : Yes
# Secret   : YES — different value from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET

# Purpose  : Expiry duration of refresh tokens
# Required : No (defaults to 7d)
# Secret   : No
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Purpose  : Comma-separated list of allowed client origins
# Required : Yes
# Secret   : No
# Example  : https://fanvault.example.com
CORS_ORIGIN=https://fanvault.example.com
